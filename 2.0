<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rocket Relay — Banker Script Console</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#111111;
    --ink-soft:#262626;
    --ink-line:#3A3A3A;
    --paper:#FFFFFF;
    --paper-dim:#F2F2F2;
    --text-dark:#16241F;
    --text-light:#FFFFFF;
    --text-muted:#9A9A9A;
    --slate:#2B2B2B;
    --brass:#DE3341;
    --brass-dark:#B81F2C;
    --brick:#2F5C8A;
    --radius:10px;
    --shadow:0 8px 24px rgba(8,16,20,0.35);
    --amber:#D97706;
    --amber-bg:rgba(217,119,6,0.08);
    --amber-border:rgba(217,119,6,0.28);
    --teal:#0E7A6A;
    --teal-bg:rgba(14,122,106,0.08);
    --teal-border:rgba(14,122,106,0.28);
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      radial-gradient(circle at 18% 12%, rgba(222,51,65,0.07), transparent 40%),
      var(--ink);
    color:var(--text-light);
    font-family:'Inter',sans-serif;
    min-height:100vh;
  }
  .app{max-width:1240px;margin:0 auto;padding:28px 22px 40px;}

  /* ---------- Topbar ---------- */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    flex-wrap:wrap;gap:14px;
    padding:16px 22px;border-radius:var(--radius);
    background:var(--brass);
    margin-bottom:22px;
    box-shadow:var(--shadow);
  }
  .brand{display:flex;align-items:center;gap:10px;}
  .brand-mark{flex-shrink:0;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.15));}
  .brand-name{font-family:'Archivo',sans-serif;font-weight:800;font-size:1.5rem;letter-spacing:0.01em;color:#fff;}
  .call-meta{display:flex;align-items:center;gap:8px;font-size:0.85rem;color:rgba(255,255,255,0.85);flex-wrap:wrap;}
  .meta-value{color:#fff;font-weight:700;}
  .divider{opacity:0.6;}
  .status-pill{
    font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;
    padding:6px 12px;border-radius:999px;
    background:rgba(255,255,255,0.16);
    border:1px solid rgba(255,255,255,0.4);
    color:#fff;font-weight:700;
    transition:all .2s ease;
  }
  .status-pill.sent{background:#fff;border-color:#fff;color:#1E7A46;}
  .reset-link{
    background:none;border:none;color:rgba(255,255,255,0.8);font-size:0.78rem;
    cursor:pointer;text-decoration:underline;text-underline-offset:3px;
    font-family:'Inter',sans-serif;padding:0;
  }
  .reset-link:hover{color:#fff;}

  /* ---------- Workspace grid ---------- */
  .workspace{
    display:grid;
    grid-template-columns:1.1fr 60px 1fr;
    gap:0;
    align-items:stretch;
  }
  .panel{
    background:var(--paper);
    color:var(--text-dark);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    display:flex;flex-direction:column;
    min-height:560px;
  }
  .panel-head{padding:20px 22px 10px;border-bottom:1px solid var(--paper-dim);}
  .panel-head h2{font-family:'Archivo',sans-serif;font-size:1.05rem;font-weight:700;margin:0 0 4px;}
  .hint{margin:0;font-size:0.8rem;color:#5A6B63;}

  /* ---------- Transcript ---------- */
  .transcript-list{padding:8px 14px 18px;overflow-y:auto;flex:1;}
  .t-line{
    display:flex;gap:12px;
    padding:10px 12px;margin:3px 0;border-radius:7px;
    cursor:pointer;
    border:1px solid transparent;
    transition:background .15s ease,border-color .15s ease;
  }
  .t-line:hover{background:rgba(74,107,124,0.08);}
  .t-line.marked{background:rgba(222,51,65,0.10);border-color:rgba(222,51,65,0.4);}
  .t-time{font-family:'IBM Plex Mono',monospace;font-size:0.72rem;color:#7A8B82;width:42px;flex-shrink:0;padding-top:2px;}
  .t-body{flex:1;}
  .t-speaker{font-family:'IBM Plex Mono',monospace;font-size:0.7rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;display:block;margin-bottom:2px;}
  .t-speaker.banker{color:var(--slate);}
  .t-speaker.client{color:var(--brick);}
  .t-text{font-family:'IBM Plex Mono',monospace;font-size:0.86rem;line-height:1.5;color:var(--text-dark);}
  .t-mark-icon{
    width:18px;height:18px;flex-shrink:0;border-radius:50%;
    border:1.5px solid #B7C2B3;margin-top:2px;
    display:flex;align-items:center;justify-content:center;
    font-size:0.65rem;color:transparent;
    transition:all .15s ease;
  }
  .t-line.marked .t-mark-icon{background:var(--brass);border-color:var(--brass);color:#fff;}

  /* ---------- Tape rail ---------- */
  .tape-rail{
    width:60px;
    display:flex;flex-direction:column;align-items:center;
    position:relative;padding-top:24px;
  }
  .tape-rail::before{
    content:'';position:absolute;top:0;bottom:0;left:50%;
    width:2px;background:repeating-linear-gradient(to bottom,var(--ink-line) 0 6px, transparent 6px 12px);
    transform:translateX(-50%);
  }
  .tape-strip{display:flex;flex-direction:column;gap:10px;align-items:center;z-index:1;}
  .tape-chip{
    width:38px;height:38px;border-radius:7px;
    background:var(--paper);
    border:1px solid var(--paper-dim);
    box-shadow:0 3px 8px rgba(0,0,0,0.3);
    display:flex;align-items:center;justify-content:center;
    position:relative;
    animation:dropIn .28s ease;
  }
  .tape-chip::before, .tape-chip::after{content:'';position:absolute;width:5px;height:5px;border-radius:50%;background:var(--ink);}
  .tape-chip::before{top:4px;left:4px;}
  .tape-chip::after{top:4px;right:4px;}
  .tape-chip span{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;font-weight:600;color:var(--brass-dark);}
  @keyframes dropIn{from{transform:translateY(-10px) scale(0.7);opacity:0;}to{transform:translateY(0) scale(1);opacity:1;}}
  .tape-empty{margin-top:18px;font-size:0.62rem;color:var(--text-muted);text-align:center;line-height:1.4;padding:0 4px;}

  /* ---------- Builder panel ---------- */
  .builder-panel{overflow:hidden;}

  /* ---------- Priority scoping section ---------- */
  .scope-section{
    margin:14px 22px 0;
    border-radius:9px;
    border:1px solid var(--amber-border);
    background:var(--amber-bg);
    overflow:hidden;
  }
  .scope-header{
    display:flex;align-items:center;justify-content:space-between;
    padding:11px 14px;cursor:pointer;
    user-select:none;
  }
  .scope-header-left{display:flex;align-items:center;gap:8px;}
  .scope-icon{
    width:22px;height:22px;border-radius:50%;
    background:rgba(217,119,6,0.18);
    display:flex;align-items:center;justify-content:center;
    font-size:0.75rem;
    flex-shrink:0;
  }
  .scope-title{
    font-family:'Archivo',sans-serif;font-size:0.82rem;font-weight:700;
    color:var(--amber);letter-spacing:0.02em;text-transform:uppercase;
  }
  .scope-toggle{font-size:0.7rem;color:var(--amber);opacity:0.7;transition:transform .2s;}
  .scope-toggle.open{transform:rotate(180deg);}
  .scope-body{padding:0 14px 14px;display:none;}
  .scope-body.open{display:block;}
  .scope-empty{font-size:0.8rem;color:#8A6A30;font-style:italic;}
  .scope-loading{display:flex;align-items:center;gap:8px;font-size:0.8rem;color:#8A6A30;}
  .scope-spinner{
    width:14px;height:14px;border-radius:50%;
    border:2px solid rgba(217,119,6,0.25);
    border-top-color:var(--amber);
    animation:spin .75s linear infinite;
    flex-shrink:0;
  }
  @keyframes spin{to{transform:rotate(360deg);}}
  .priority-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:7px;}
  .priority-item{
    display:flex;align-items:flex-start;gap:9px;
    padding:8px 10px;border-radius:7px;
    background:rgba(255,255,255,0.6);
    border:1px solid rgba(217,119,6,0.14);
    cursor:pointer;transition:all .15s ease;
  }
  .priority-item:hover{background:rgba(255,255,255,0.85);}
  .priority-item.dismissed{opacity:0.38;text-decoration:line-through;cursor:default;}
  .priority-badge{
    font-family:'IBM Plex Mono',monospace;font-size:0.63rem;font-weight:600;
    letter-spacing:0.06em;text-transform:uppercase;
    padding:2px 6px;border-radius:4px;flex-shrink:0;margin-top:1px;
  }
  .badge-urgent{background:rgba(222,51,65,0.12);color:var(--brass-dark);}
  .badge-action{background:rgba(14,122,106,0.12);color:var(--teal);}
  .badge-concern{background:rgba(217,119,6,0.14);color:var(--amber);}
  .priority-text{font-size:0.82rem;color:var(--text-dark);line-height:1.4;flex:1;}
  .priority-dismiss{
    font-size:0.68rem;color:#AAA;flex-shrink:0;margin-top:2px;
    background:none;border:none;cursor:pointer;padding:0;font-family:'Inter',sans-serif;
  }
  .priority-dismiss:hover{color:#888;}
  .scope-footnote{
    margin-top:10px;font-size:0.72rem;color:#9A7A40;
    padding-top:8px;border-top:1px solid rgba(217,119,6,0.15);
  }

  /* ---------- Tabs / script area ---------- */
  .tabs{display:flex;gap:6px;padding:14px 22px 0;}
  .tab{
    font-family:'Inter',sans-serif;font-size:0.78rem;font-weight:600;
    padding:7px 14px;border-radius:7px 7px 0 0;
    border:none;background:transparent;color:#7A8B82;cursor:pointer;
    border-bottom:2px solid transparent;
  }
  .tab.active{color:var(--text-dark);border-bottom-color:var(--brass);}
  .script-body{flex:1;padding:14px 22px;position:relative;}
  .script-text{
    width:100%;height:100%;min-height:200px;resize:none;
    border:1px solid var(--paper-dim);border-radius:8px;
    background:#fff;padding:14px;
    font-family:'IBM Plex Mono',monospace;font-size:0.86rem;line-height:1.55;
    color:var(--text-dark);
    display:none;
  }
  .script-text.active{display:block;}
  .script-text:read-only{background:#F4F6F0;color:#3D4A45;}

  .builder-actions{display:flex;gap:10px;padding:0 22px 20px;flex-wrap:wrap;}
  .btn{
    font-family:'Inter',sans-serif;font-weight:600;font-size:0.84rem;
    padding:11px 18px;border-radius:8px;border:none;cursor:pointer;
    transition:transform .12s ease, opacity .12s ease;
  }
  .btn:active{transform:scale(0.97);}
  .btn:disabled{opacity:0.45;cursor:not-allowed;}
  .btn-secondary{background:var(--ink-soft);color:var(--text-light);border:1px solid var(--ink-line);}
  .btn-secondary:hover:not(:disabled){background:var(--ink-line);}
  .btn-primary{background:var(--brass);color:#1C1404;}
  .btn-primary:hover:not(:disabled){background:var(--brass-dark);}
  .btn-ghost{background:transparent;color:var(--slate);border:1px solid var(--paper-dim);}

  .toast{margin:0 22px 18px;padding:11px 14px;border-radius:8px;background:rgba(91,158,120,0.14);border:1px solid rgba(91,158,120,0.4);color:#3D6B4E;font-size:0.82rem;font-weight:600;display:none;}
  .toast.show{display:block;}

  .footnote{text-align:center;margin-top:22px;font-size:0.74rem;color:var(--text-muted);}

  /* ---------- Responsive ---------- */
  @media(max-width:880px){
    .workspace{grid-template-columns:1fr;}
    .tape-rail{width:100%;flex-direction:row;padding:14px 0;}
    .tape-rail::before{top:50%;left:0;right:0;height:2px;width:auto;background:repeating-linear-gradient(to right,var(--ink-line) 0 6px, transparent 6px 12px);transform:translateY(-50%);}
    .tape-strip{flex-direction:row;flex-wrap:wrap;justify-content:center;}
    .tape-empty{margin:0 0 0 10px;}
    .panel{min-height:auto;}
  }
</style>
</head>
<body>
<div class="app">

  <header class="topbar">
    <div class="brand">
      <svg class="brand-mark" viewBox="0 0 24 24" width="26" height="26" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2c2.6 2.1 4.1 5.7 4.1 9.6 0 2.1-.5 4-1.3 5.5l-2.8 1.7-2.8-1.7C8.4 15.6 7.9 13.7 7.9 11.6 7.9 7.7 9.4 4.1 12 2z" fill="#fff"/>
        <circle cx="12" cy="9.2" r="1.5" fill="var(--brass)"/>
        <path d="M7.9 12.6c-1.9.5-3.2 2-3.2 4.9 1.9-.5 3.2-1.5 3.9-2.8" fill="#fff"/>
        <path d="M16.1 12.6c1.9.5 3.2 2 3.2 4.9-1.9-.5-3.2-1.5-3.9-2.8" fill="#fff"/>
        <path d="M9.9 18.4h4.2l-1.3 2.9a.85.85 0 0 1-1.6 0l-1.3-2.9z" fill="#fff" opacity="0.85"/>
      </svg>
      <span class="brand-name">Rocket Relay</span>
    </div>
    <div class="call-meta">
      <span class="meta-label">Call</span><span class="meta-value">#4471</span>
      <span class="divider">·</span>
      <span class="meta-label">Banker</span><span class="meta-value">Jordan Alvarez</span>
      <span class="divider">·</span>
      <span class="meta-label">Client</span><span class="meta-value">Morgan Lee</span>
    </div>
    <div style="display:flex;align-items:center;gap:14px;">
      <div class="status-pill" id="statusPill">Reviewing</div>
      <button class="reset-link" id="resetBtn">Reset demo</button>
    </div>
  </header>

  <div class="workspace">

    <section class="panel transcript-panel">
      <div class="panel-head">
        <h2>Call transcript</h2>
        <p class="hint">Tap a line to mark it as a key moment for the client script.</p>
      </div>
      <div class="transcript-list" id="transcriptList"></div>
    </section>

    <div class="tape-rail">
      <div class="tape-strip" id="tapeStrip"></div>
      <div class="tape-empty" id="tapeEmpty">No moments<br>marked yet</div>
    </div>

    <section class="panel builder-panel">
      <div class="panel-head">
        <h2>Script builder</h2>
        <p class="hint" id="builderHint">Mark moments in the transcript, then generate a draft.</p>
      </div>

      <div class="scope-section" id="scopeSection">
        <div class="scope-header" id="scopeHeader">
          <div class="scope-header-left">
            <div class="scope-icon">⚡</div>
            <span class="scope-title">Client priorities</span>
          </div>
          <span class="scope-toggle" id="scopeToggle">▼</span>
        </div>
        <div class="scope-body open" id="scopeBody">
          <p class="scope-empty" id="scopeEmpty">Mark moments from the transcript to surface Morgan's priorities.</p>
          <div id="scopeLoading" style="display:none;" class="scope-loading">
            <div class="scope-spinner"></div>
            <span>Scoping client priorities…</span>
          </div>
          <ul class="priority-list" id="priorityList"></ul>
          <p class="scope-footnote" id="scopeFootnote" style="display:none;">Click any priority to remove it from scope before generating the script.</p>
        </div>
      </div>

      <div class="tabs">
        <button class="tab active" data-tab="sms">SMS</button>
        <button class="tab" data-tab="voice">Voice AI</button>
      </div>

      <div class="script-body">
        <textarea class="script-text active" id="smsText" placeholder="The SMS draft will appear here once you generate a script."></textarea>
        <textarea class="script-text" id="voiceText" placeholder="The Voice AI script will appear here once you generate a script."></textarea>
      </div>

      <div class="builder-actions">
        <button class="btn btn-secondary" id="generateBtn" disabled>Generate script</button>
        <button class="btn btn-primary" id="approveBtn" disabled>Approve &amp; send</button>
        <button class="btn btn-ghost" id="editBtn" style="display:none;">Make changes</button>
      </div>
      <div class="toast" id="toast"></div>
    </section>

  </div>

  <p class="footnote">Rocket Relay is a concept mockup styled for Rocket Mortgage with a sample call — not an official Rocket Mortgage product, and not connected to a live call vendor or messaging system.</p>
</div>

<script>
const transcript = [
  {id:1, time:'00:02', speaker:'banker', text:"Hi Morgan, this is Jordan from the lending team — thanks for calling back about your refinance."},
  {id:2, time:'00:14', speaker:'client', text:"Hi Jordan, yes — I wanted to check where things stand before my rate lock runs out."},
  {id:3, time:'00:28', speaker:'banker', text:"Good timing. Your rate is locked at 6.125% and that lock expires June 30."},
  {id:4, time:'00:55', speaker:'banker', text:"To stay on track, we still need your most recent pay stub and a bank statement by June 26."},
  {id:5, time:'01:20', speaker:'client', text:"And if those documents come in a little late?"},
  {id:6, time:'01:32', speaker:'banker', text:"We can extend the lock, but an extension carries a 0.25 point fee, so it's best to get them in by the 26th if we can."},
  {id:7, time:'02:05', speaker:'banker', text:"You can upload everything through the secure portal, or email it straight to me — whichever's easier."},
  {id:8, time:'02:30', speaker:'banker', text:"If anything comes up, my direct line is 555-0148 — that goes straight to me, not a queue."},
  {id:9, time:'02:50', speaker:'client', text:"That's helpful, thank you. I think I follow everything."},
  {id:10,time:'03:02', speaker:'banker', text:"One last thing — your closing disclosure will land in your inbox three days before the July 15 closing, so keep an eye out for it."}
];

const state = {
  marked: [],
  priorities: [],
  prioritiesScoped: false,
  scripts: { sms:'', voice:'' },
  approved: false
};

const listEl        = document.getElementById('transcriptList');
const tapeStrip     = document.getElementById('tapeStrip');
const tapeEmpty     = document.getElementById('tapeEmpty');
const generateBtn   = document.getElementById('generateBtn');
const approveBtn    = document.getElementById('approveBtn');
const editBtn       = document.getElementById('editBtn');
const statusPill    = document.getElementById('statusPill');
const toast         = document.getElementById('toast');
const builderHint   = document.getElementById('builderHint');
const smsText       = document.getElementById('smsText');
const voiceText     = document.getElementById('voiceText');
const scopeBody     = document.getElementById('scopeBody');
const scopeToggle   = document.getElementById('scopeToggle');
const scopeEmpty    = document.getElementById('scopeEmpty');
const scopeLoading  = document.getElementById('scopeLoading');
const priorityList  = document.getElementById('priorityList');
const scopeFootnote = document.getElementById('scopeFootnote');

document.getElementById('scopeHeader').addEventListener('click', () => {
  const open = scopeBody.classList.toggle('open');
  scopeToggle.classList.toggle('open', open);
});

function renderTranscript(){
  listEl.innerHTML = transcript.map(line => `
    <div class="t-line ${state.marked.includes(line.id) ? 'marked' : ''}" data-id="${line.id}">
      <span class="t-time">${line.time}</span>
      <span class="t-mark-icon">✓</span>
      <div class="t-body">
        <span class="t-speaker ${line.speaker}">${line.speaker === 'banker' ? 'Jordan · Rocket Mortgage' : 'Morgan (client)'}</span>
        <span class="t-text">${line.text}</span>
      </div>
    </div>
  `).join('');
  listEl.querySelectorAll('.t-line').forEach(el => {
    el.addEventListener('click', () => toggleMark(parseInt(el.dataset.id)));
  });
}

function toggleMark(id){
  if(state.approved) return;
  const i = state.marked.indexOf(id);
  if(i === -1) state.marked.push(id); else state.marked.splice(i,1);
  state.marked.sort((a,b)=>a-b);
  renderTranscript();
  renderTape();
  state.priorities = [];
  state.prioritiesScoped = false;
  renderPriorities();
  generateBtn.disabled = true;
  if(state.marked.length > 0){
    scopeClientPriorities();
  } else {
    builderHint.textContent = 'Mark moments in the transcript, then generate a draft.';
    scopeEmpty.style.display = 'block';
  }
}

function renderTape(){
  if(state.marked.length === 0){
    tapeStrip.innerHTML = '';
    tapeEmpty.style.display = 'block';
    return;
  }
  tapeEmpty.style.display = 'none';
  tapeStrip.innerHTML = state.marked.map((id,idx) => `<div class="tape-chip"><span>${idx+1}</span></div>`).join('');
}

function setTab(tab){
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  smsText.classList.toggle('active', tab === 'sms');
  voiceText.classList.toggle('active', tab === 'voice');
}
document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => setTab(t.dataset.tab)));

function renderPriorities(){
  priorityList.innerHTML = '';
  if(state.priorities.length === 0){ scopeFootnote.style.display='none'; return; }
  scopeFootnote.style.display = 'block';
  state.priorities.forEach((p, idx) => {
    const li = document.createElement('li');
    li.className = 'priority-item' + (p.dismissed ? ' dismissed' : '');
    li.innerHTML = `
      <span class="priority-badge badge-${p.badge}">${p.badge}</span>
      <span class="priority-text">${p.text}</span>
      ${!p.dismissed ? `<button class="priority-dismiss" data-idx="${idx}" title="Remove from scope">✕</button>` : ''}
    `;
    if(!p.dismissed){
      li.querySelector('.priority-dismiss').addEventListener('click', (e) => {
        e.stopPropagation();
        state.priorities[idx].dismissed = true;
        renderPriorities();
      });
    }
    priorityList.appendChild(li);
  });
}

function localPriorityFallback(lines){
  const priorities = [];
  if(lines.some(l => /June 26|deadline|due|by the/.test(l.text)))
    priorities.push({badge:'urgent', text:'Rate lock expires June 30 — documents needed by June 26 to avoid an extension fee.', dismissed:false});
  if(lines.some(l => /document|pay stub|bank statement|upload/.test(l.text)))
    priorities.push({badge:'action', text:'Submit pay stub and bank statement through the secure portal or via email.', dismissed:false});
  if(lines.some(l => /fee|point|cost/.test(l.text)))
    priorities.push({badge:'concern', text:'Understands that a late extension carries a 0.25 point fee.', dismissed:false});
  if(lines.some(l => /closing|July 15|disclosure/.test(l.text)))
    priorities.push({badge:'action', text:'Watch inbox for closing disclosure arriving three days before July 15 closing.', dismissed:false});
  if(priorities.length === 0)
    priorities.push({badge:'action', text:'Follow up on next steps from the call.', dismissed:false});
  return priorities;
}

async function scopeClientPriorities(){
  scopeEmpty.style.display = 'none';
  scopeLoading.style.display = 'flex';
  priorityList.innerHTML = '';
  scopeFootnote.style.display = 'none';
  generateBtn.disabled = true;
  builderHint.textContent = "Scoping Morgan's priorities…";

  const lines = transcript.filter(l => state.marked.includes(l.id));
  const prompt = `You are an analyst reviewing key moments from a mortgage call between banker Jordan Alvarez (Rocket Mortgage) and client Morgan Lee.

Marked moments from the call:
${lines.map(l => `- (${l.speaker === 'banker' ? 'Banker' : 'Client'}) ${l.text}`).join('\n')}

Identify 2–4 of Morgan's main priorities, concerns, or required actions from these moments. For each one:
- Assign a badge: "urgent" (time-sensitive), "action" (something Morgan needs to do), or "concern" (something Morgan is worried about or unclear on)
- Write a single clear sentence (max 18 words) summarising the priority from Morgan's perspective

Respond ONLY with a JSON array, no markdown fences, no extra text:
[{"badge":"urgent|action|concern","text":"..."},...]`;

  try{
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-6",
        max_tokens:600,
        messages:[{role:"user", content:prompt}]
      })
    });
    const data = await response.json();
    const text = (data.content||[]).map(c=>c.text||'').join('\n');
    const parsed = JSON.parse(text.replace(/```json|```/g,'').trim());
    state.priorities = parsed.map(p => ({...p, dismissed:false}));
  } catch(err){
    console.error('Priority scoping failed, using fallback:', err);
    state.priorities = localPriorityFallback(lines);
  }

  state.prioritiesScoped = true;
  scopeLoading.style.display = 'none';
  renderPriorities();
  generateBtn.disabled = false;
  builderHint.textContent = `${state.marked.length} moment${state.marked.length>1?'s':''} marked — review priorities, then generate.`;
}

function localFallback(lines){
  const summary = lines.map(l => l.text.replace(/\.$/, '')).join('; ');
  const sms = `Hi Morgan, it's Jordan at Rocket Mortgage with a quick recap: ${summary}. Questions? Call me directly at 555-0148.`.slice(0,320);
  const voice = `Hi Morgan, this is a follow-up from Rocket Mortgage on your call with Jordan. Here's a quick recap: ${summary}. If anything's unclear, you can reach Jordan directly at 555-0148. Thanks for choosing Rocket Mortgage.`;
  return { sms, voice };
}

async function generateScript(){
  const lines = transcript.filter(l => state.marked.includes(l.id));
  const activePriorities = state.priorities.filter(p => !p.dismissed);
  generateBtn.disabled = true;
  generateBtn.textContent = 'Generating…';

  const priorityBlock = activePriorities.length > 0
    ? `\nClient's confirmed priorities (must be addressed in the script):\n${activePriorities.map(p=>`- [${p.badge.toUpperCase()}] ${p.text}`).join('\n')}`
    : '';

  const prompt = `You are helping a Rocket Mortgage banker turn marked moments from a client call into two short client-facing follow-up messages.
Banker name: Jordan Alvarez, Rocket Mortgage. Client name: Morgan Lee.

Marked moments from the call, in order:
${lines.map(l => `- (${l.speaker}) ${l.text}`).join('\n')}
${priorityBlock}

Write:
1. "sms": a text message under 300 characters, warm and professional, addressing the client's priorities, signed informally by Jordan from Rocket Mortgage.
2. "voice": a spoken follow-up script for a voice assistant to read to the client, 60-100 words, conversational and clear, covering the priorities, mentioning Rocket Mortgage once.

Respond with ONLY a JSON object, no markdown fences, no extra text: {"sms": "...", "voice": "..."}`;

  try{
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({
        model:"claude-sonnet-4-6",
        max_tokens:1000,
        messages:[{role:"user", content:prompt}]
      })
    });
    const data = await response.json();
    const text = (data.content||[]).map(c=>c.text||'').join('\n');
    const parsed = JSON.parse(text.replace(/```json|```/g,'').trim());
    state.scripts.sms = parsed.sms || '';
    state.scripts.voice = parsed.voice || '';
  }catch(err){
    console.error('Generation failed, using local draft:', err);
    const fb = localFallback(lines);
    state.scripts.sms = fb.sms;
    state.scripts.voice = fb.voice;
  }

  smsText.value = state.scripts.sms;
  voiceText.value = state.scripts.voice;
  generateBtn.disabled = false;
  generateBtn.textContent = 'Regenerate script';
  approveBtn.disabled = false;
  builderHint.textContent = 'Draft ready — review, edit if needed, then approve.';
}

generateBtn.addEventListener('click', generateScript);

approveBtn.addEventListener('click', () => {
  state.approved = true;
  smsText.readOnly = true;
  voiceText.readOnly = true;
  approveBtn.style.display = 'none';
  generateBtn.style.display = 'none';
  editBtn.style.display = 'inline-block';
  statusPill.textContent = 'Sent';
  statusPill.classList.add('sent');
  toast.textContent = 'Sent to Morgan Lee · Rocket Mortgage scripts delivered as SMS and Voice AI follow-up.';
  toast.classList.add('show');
  builderHint.textContent = 'Approved and sent.';
});

editBtn.addEventListener('click', () => {
  state.approved = false;
  smsText.readOnly = false;
  voiceText.readOnly = false;
  approveBtn.style.display = 'inline-block';
  generateBtn.style.display = 'inline-block';
  editBtn.style.display = 'none';
  statusPill.textContent = 'Reviewing';
  statusPill.classList.remove('sent');
  toast.classList.remove('show');
  builderHint.textContent = 'Editing — approve again when ready.';
});

document.getElementById('resetBtn').addEventListener('click', () => {
  state.marked = [];
  state.priorities = [];
  state.prioritiesScoped = false;
  state.scripts = { sms:'', voice:'' };
  state.approved = false;
  smsText.value = ''; voiceText.value = '';
  smsText.readOnly = false; voiceText.readOnly = false;
  approveBtn.disabled = true; approveBtn.style.display = 'inline-block';
  generateBtn.disabled = true; generateBtn.style.display = 'inline-block'; generateBtn.textContent = 'Generate script';
  editBtn.style.display = 'none';
  statusPill.textContent = 'Reviewing'; statusPill.classList.remove('sent');
  toast.classList.remove('show');
  builderHint.textContent = 'Mark moments in the transcript, then generate a draft.';
  scopeEmpty.style.display = 'block';
  scopeLoading.style.display = 'none';
  priorityList.innerHTML = '';
  scopeFootnote.style.display = 'none';
  setTab('sms');
  renderTranscript();
  renderTape();
});

renderTranscript();
renderTape();
</script>
</body>
</html>
